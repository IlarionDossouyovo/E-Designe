{
  "name": "ELECTRON - Support Client IA",
  "nodes": [
    {
      "id": "webhook",
      "name": "Support Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [220, 300],
      "parameters": {
        "httpMethod": "POST",
        "path": "electron-support"
      }
    },
    {
      "id": "classify",
      "name": "Classify Issue with AI",
      "type": "ollamaAi",
      "typeVersion": 1,
      "position": [440, 300],
      "parameters": {
        "url": "http://localhost:11434",
        "model": "llama2",
        "prompt": "Tu es un assistant de support client pour ELECTRON. Classe cette demande en une de ces categories:\\n- LIVRAISON: questions sur la livraison, le suivi\\n- RETOUR: demandes de retour, remboursement\\n- PAIEMENT: probleme de paiement,Stripe,PayPal\\n- PRODUIT: question sur un produit, taille\\n- AUTRE: autre demande\\n\\nRenvoie uniquement le nom de la categorie en un mot.",
        "options": {}
      }
    },
    {
      "id": "switch",
      "name": "Category Switch",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3,
      "position": [660, 300],
      "parameters": {
        "dataType": "string",
        "value1": "={{ $json.classification }}",
        "operation": "equal",
        "value2": "LIVRAISON",
        "rules": {
          "cases": [
            {"operation": "equal", "value2": "LIVRAISON", "output": 0},
            {"operation": "equal", "value2": "RETOUR", "output": 1},
            {"operation": "equal", "value2": "PAIEMENT", "output": 2},
            {"operation": "equal", "value2": "PRODUIT", "output": 3},
            {"operation": "equal", "value2": "AUTRE", "output": 4}
          ]
        }
      }
    },
    {
      "id": "delivery",
      "name": "Delivery Response",
      "type": "ollamaAi",
      "typeVersion": 1,
      "position": [880, 100],
      "parameters": {
        "url": "http://localhost:11434",
        "model": "llama2",
        "prompt": "Reponds en francais au client ELECTRON pour une question sur la LIVRAISON. Voici sa question: {{ $json.message }}\\n\\nInfos livraison ELECTRON:\\n- Livraison: 3-5 jours ouvres\\n- Suivi: disponible via email\\n- Frais: gratuits pour commandes +50 euros\\n- Zone: Benin, Afrique de l'Ouest"
      }
    },
    {
      "id": "return",
