      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1,
      "position": [
        100,
        300
      ]
    },
    {
      "parameters": {
        "operation": "readAll",
        "fileName": "db/contacts.json",
        "limit": 100
      },
      "id": "r1",
      "name": "Read",
      "type": "n8n-nodes-base.readBinaryFiles",
      "typeVersion": 1,
      "position": [
        300,
        300
      ]
    },
    {
      "parameters": {
        "subject": "Rapport",
        "additionalFields": {}
      },
      "id": "e1",
      "name": "Email",
      "type": "n8n-nodes-base.gmail",
      "typeVersion": 1,
      "position": [
        500,
        300
      ]
    }
  ],
  "connections": {
    "t1": {
      "main": [
        [
          {
            "node": "r1",
