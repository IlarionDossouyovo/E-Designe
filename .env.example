# E-Désigne Environment Configuration
# Copy this file to .env and customize

# Server Port
PORT=3000

# ============================================
# RESEND - Emails Transactionnels
# ============================================
# Obtenez votre clé API sur: https://resend.com
RESEND_API_KEY=re_Dj8diRCn_CJ1eDHXVtSKWdbYRw5TRz4ok
FROM_EMAIL=noreply@e-designe.com
SUPPORT_EMAIL=support@e-designe.com

# ============================================
# STRIPE - Paiements
# ============================================
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_PUBLIC_KEY=pk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ============================================
# PAYPAL - Paiements
# ============================================
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret

# ============================================
# SUPABASE - Base de données
# ============================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key

# ============================================
# FIREBASE (Optionnel)
# ============================================
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_PROJECT_ID=your_firebase_project_id

# ============================================
# URL du Site
# ============================================
VITE_SITE_URL=https://e-designe.vercel.app

# Ollama Configuration
# Make sure Ollama is running locally: ollama serve
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama2

# Frontend runs on 5173 by default with Vite
VITE_API_URL=http://localhost:3000
VITE_OLLAMA_URL=http://localhost:11434
VITE_OLLAMA_MODEL=llama2