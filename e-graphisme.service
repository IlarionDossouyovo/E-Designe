[Unit]
Description=E-Graphisme Auto-Start System
After=network.target docker.service
Requires=docker.service

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=/workspace/project/E-Graphisme
ExecStart=/workspace/project/E-Graphisme/AUTO-START-SYSTEM.sh
ExecStop=/workspace/project/E-Graphisme/AUTO-STOP-SYSTEM.sh
User=openhands

[Install]
WantedBy=multi-user.target